#!/usr/bin/env python3
# reader:linkedin — traffic-informed (promoted from a blind net after seeing real
# browsing in /tmp/chat-collector.log).
# STRUCTURE differs from youtube: LinkedIn funnels most content through ONE
# endpoint /voyager/api/graphql (the operation is in the ?queryId param, not the
# path) plus a second surface /rest/. So graphql is keyed by its query param —
# otherwise every operation collapses into one file.
#
# CONTENT observed:  /voyager/api/graphql (feed/profile/search — op in ?queryId),
#                    /voyager/api/messaging/*, voyagerMessaging*, identity/*, me,
#                    /rest/* (newer content surface)
# NOISE observed:    /sensor, /li/, /realtime, tscp-serving, litms, log_event
import sys, json, os, re
from urllib.parse import urlparse, parse_qs

OUT = os.path.expanduser(os.environ.get("CHAT_DUMPS", "~/chat-dumps") + "/linkedin")
KEEP = re.compile(r"/voyager/api/(graphql|messaging/|voyagerMessaging|identity/|me\b)|/rest/")
SKIP = re.compile(r"/sensor|/li/|/realtime|tscp-serving|litms|log_event|/rest/track")

def name_for(url):
    u = urlparse(url)
    path = re.sub(r"[^a-zA-Z0-9]+", "-", u.path).strip("-")
    q = parse_qs(u.query)
    op = (q.get("queryId") or q.get("q") or [""])[0]          # differentiate graphql ops
    op = re.sub(r"[^a-zA-Z0-9]+", "-", op).strip("-")
    return (path + ("-" + op if op else ""))[:120] or "root"

for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        rec = json.loads(line)
    except Exception:
        continue
    url = rec.get("url", "")
    if rec.get("status") != 200 or SKIP.search(url) or not KEEP.search(url):
        continue
    os.makedirs(OUT, exist_ok=True)
    name = name_for(url)
    body = rec.get("body", "")
    try:
        out = json.dumps(json.loads(body), ensure_ascii=False, indent=2)
    except Exception:
        out = body
    with open(os.path.join(OUT, name + ".json"), "w") as f:
        f.write(out)
    print(f"[reader:linkedin] {name}", file=sys.stderr)
