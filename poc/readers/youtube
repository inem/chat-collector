#!/usr/bin/env python3
# reader:youtube — traffic-informed (promoted from a blind net after seeing real
# browsing in /tmp/tap.log). Keeps the content-bearing endpoints,
# skips the telemetry firehose. Tune the sets as more traffic shows up.
#
# CONTENT observed:  youtubei/v1/{player,browse,get_watch,guide,live_chat/*},
#                    /api/timedtext  (subtitles — NOT under youtubei/, matched separately)
# NOISE observed:    updated_metadata, log_event, player/heartbeat, api/stats/*, qoe
import sys, json, os, re

OUT = os.path.expanduser(os.environ.get("TAP_OUT", "~/tap-out") + "/youtube")
KEEP = re.compile(r"/youtubei/v1/(player|browse|get_watch|guide|search|live_chat/[a-z_]+)(?:$|\?)"
                  r"|/api/timedtext")
SKIP = re.compile(r"updated_metadata|log_event|heartbeat|/api/stats/|/qoe")

def slug(url):
    path = re.sub(r"^https?://[^/]+", "", url).split("?")[0]
    return re.sub(r"[^a-zA-Z0-9]+", "-", path).strip("-")[:120] or "root"

for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        rec = json.loads(line)
    except Exception:
        continue
    url = rec.get("url", "")
    if rec.get("status") != 200 or SKIP.search(url) or not KEEP.search(url):
        continue
    os.makedirs(OUT, exist_ok=True)
    name = slug(url)
    body = rec.get("body", "")
    try:
        out = json.dumps(json.loads(body), ensure_ascii=False, indent=2)
    except Exception:
        out = body
    with open(os.path.join(OUT, name + ".json"), "w") as f:
        f.write(out)
    print(f"[reader:youtube] {name}", file=sys.stderr)
