#!/bin/bash
# chat-collector: one fail-safe handle for the whole thing.
#
# The ONLY thing that can break your net is "proxy armed + no live proxy behind
# 8899". Three guards make that state impossible:
#   ON  arms the proxy, then makes a REAL request through it; if nothing flows
#       it auto-disarms and aborts (self-healing rollback).
#   OFF disarms the proxy, confirms it read back off, THEN kills mitmdump and
#       WAITS for it to actually die (SIGKILL if it lingers) — no async lies.
#   We never trust networksetup's exit code — we read state back / test traffic.
#
# macOS needs admin to flip the system proxy — via the one-time sudoers rule
# (sudoers.snippet) so on/off run silently. Without it, `on` aborts cleanly.
#
# Usage: collector on | off | status
set -uo pipefail

PORT=8899
SVC="Wi-Fi"                              # `networksetup -listnetworkserviceorder`
ADDON="$HOME/Code/chat-collector/chat_collector.py"
LOG="/tmp/chat-collector.log"
PATTERN="mitmdump.*chat_collector.py"
NS=/usr/sbin/networksetup

proc_up() { pgrep -f "$PATTERN" >/dev/null; }
port_up() { nc -z 127.0.0.1 "$PORT" 2>/dev/null; }
# armed = EITHER proxy on. HTTPS (your API + the chat traffic) rides the SECURE
# one, so checking only web/http was the blind spot that hid live interception.
armed()   { $NS -getwebproxy "$SVC" | grep -q "Enabled: Yes" \
         || $NS -getsecurewebproxy "$SVC" | grep -q "Enabled: Yes"; }
# a REAL request through the proxy must return an HTTP response
flows()   { curl -s -o /dev/null --max-time 6 -x "http://127.0.0.1:$PORT" http://example.com; }

start_proc() {                            # ensure a live proxy serves 8899
  proc_up && port_up && return 0
  mitmdump -s "$ADDON" -p "$PORT" >"$LOG" 2>&1 &
  for _ in $(seq 20); do port_up && return 0; sleep 0.5; done
  return 1
}
stop_proc() {                             # kill AND wait for real death
  pkill -TERM -f "$PATTERN" 2>/dev/null
  for _ in $(seq 20); do proc_up || return 0; sleep 0.25; done
  pkill -KILL -f "$PATTERN" 2>/dev/null   # escalate if it hung
  for _ in $(seq 8); do proc_up || return 0; sleep 0.25; done
  return 1
}

arm_proxy() {                             # needs the sudoers rule (sudoers.snippet)
  sudo -n $NS -setwebproxy "$SVC" 127.0.0.1 "$PORT" 2>/dev/null
  sudo -n $NS -setsecurewebproxy "$SVC" 127.0.0.1 "$PORT" 2>/dev/null
  sudo -n $NS -setproxybypassdomains "$SVC" localhost 127.0.0.1 '*.local' 2>/dev/null
  armed
}
disarm_proxy() {
  sudo -n $NS -setwebproxystate "$SVC" off 2>/dev/null
  sudo -n $NS -setsecurewebproxystate "$SVC" off 2>/dev/null
  ! armed                                 # verify it actually read back OFF
}

if [ -t 1 ]; then G=$'\e[32m'; D=$'\e[2m'; R=$'\e[31m'; Y=$'\e[33m'; Z=$'\e[0m'; else G= D= R= Y= Z=; fi

case "${1:-status}" in
  on)
    start_proc || { echo "ABORT: mitmdump didn't come up on $PORT — proxy untouched, net safe"; exit 1; }
    arm_proxy  || { echo "ABORT: couldn't arm proxy — mitmdump runs but proxy is off, net safe"; exit 1; }
    if flows; then
      echo "ON — $SVC -> 127.0.0.1:$PORT, dumps in ~/chat-dumps/, log $LOG"
    else
      disarm_proxy >/dev/null            # AUTO-ROLLBACK: armed but nothing flows
      echo "ABORT: proxy armed but no traffic flowed through it — disarmed again, net safe"; exit 1
    fi
    ;;
  off)
    disarm_proxy || { echo "REFUSING to kill mitmdump: can't confirm proxy is off — net would break. Fix proxy, rerun."; exit 1; }
    if stop_proc; then echo "OFF — proxy disarmed (verified), mitmdump stopped (confirmed dead)"
    else               echo "OFF — proxy disarmed, but a mitmdump WON'T DIE; check: pgrep -fl mitmdump"; exit 1; fi
    ;;
  status)
    if [ "${2:-}" = "--verbose" ] || [ "${2:-}" = "-v" ]; then
      wh=$($NS -getwebproxy       "$SVC" | awk '/^Enabled/{print $2}')
      ws=$($NS -getsecurewebproxy "$SVC" | awk '/^Enabled/{print $2}')
      echo
      if proc_up; then
        echo "  ${G}●${Z} mitmproxy  ${D}· $(pgrep -f "$PATTERN" | head -1)${Z}"
        echo "     ${D}the always-on recorder. anything captured passes through here.${Z}"
      else
        echo "  ${R}✗ mitmproxy — not running${Z}"
        echo "     ${D}nothing is being recorded right now.${Z}"
      fi
      echo
      if armed; then
        echo "  ${G}●${Z} browser/apps  ${D}capturing${Z}"
        echo "     ${D}your browser & any GUI app that honors the system proxy → ~/chat-dumps${Z}"
      else
        echo "  ${D}○ browser/apps  direct${Z}"
        echo "     ${D}NOT recorded — run 'collector on' to start${Z}"
      fi
      echo "     ${D}(system proxy: http=$wh  https=$ws)${Z}"
      echo
      echo "  ${D}────────${Z}"
      if ! proc_up && armed; then
        echo "  ${Y}⚠ broken: the proxy is armed but the recorder is down. Run 'collector off' or restart the service.${Z}"
      elif proc_up && armed; then
        echo "  ${G}✓ recording${Z} ${D}— launchd keeps mitmproxy up, so nothing breaks.${Z}"
      elif proc_up; then
        echo "  ${D}○ idle — recorder up but capturing nothing. 'collector on' to record the browser.${Z}"
      else
        echo "  ${D}○ off — recorder down, browser direct.${Z}"
      fi
      echo
    else
      # compact: two aligned lines + a warning only when something's wrong
      if proc_up; then echo "mitmproxy     ${G}●${Z} up ${D}· $(pgrep -f "$PATTERN" | head -1)${Z}"
      else             echo "mitmproxy     ${R}✗ down${Z} ${D}· not running${Z}"; fi
      armed && echo "browser/apps  ${G}● capturing${Z}"                     || echo "browser/apps  ${D}○ direct${Z}   ${D}(collector on)${Z}"
      if ! proc_up && armed; then
        echo "${Y}⚠  proxy armed but mitmproxy is down — GUI-app traffic is broken.${Z}"
      fi
    fi
    ;;
  doctor)
    # one-time setup health: is the install correct? (distinct from runtime status)
    ok()   { printf "  ${G}●${Z} %-30s ${D}%s${Z}\n" "$1" "${2:-}"; }
    bad()  { echo "  ${R}✗${Z} $1"; echo "     ${D}fix: $2${Z}"; }
    echo
    command -v mitmdump >/dev/null \
      && ok "recorder installed" "mitmproxy" \
      || bad "recorder missing" "brew install mitmproxy"

    [ -f "$HOME/.mitmproxy/mitmproxy-ca-cert.pem" ] \
      && ok "HTTPS key ready" "~/.mitmproxy/mitmproxy-ca-cert.pem" \
      || bad "no HTTPS key — encrypted traffic unreadable" "launchctl bootstrap gui/\$(id -u) ~/Library/LaunchAgents/com.chat-collector.plist"

    security find-certificate -c mitmproxy >/dev/null 2>&1 \
      && ok "Mac trusts the key" "verify: open mitm.it with proxy on" \
      || bad "key not trusted — HTTPS won't decrypt" "open mitm.it with proxy on, install cert, mark Always Trust"

    launchctl print "gui/$(id -u)/com.chat-collector" >/dev/null 2>&1 \
      && ok "auto-starts, survives reboot" "~/Library/LaunchAgents/com.chat-collector.plist" \
      || bad "won't restart after reboot/crash" "cp com.chat-collector.plist ~/Library/LaunchAgents/ && launchctl bootstrap gui/\$(id -u) ~/Library/LaunchAgents/com.chat-collector.plist"

    sudo -n -l $NS -setwebproxystate "$SVC" off >/dev/null 2>&1 \
      && ok "on/off silent, no password" "/etc/sudoers.d/chat-collector" \
      || bad "on/off will prompt for a password" "sudo visudo -f /etc/sudoers.d/chat-collector  (paste sudoers.snippet)"

    port_up \
      && ok "capturing right now" "port $PORT -> ~/chat-dumps/" \
      || bad "recorder is down right now" "launchctl kickstart -k gui/\$(id -u)/com.chat-collector"
    echo
    ;;
  where)
    echo
    echo "  ${D}you run${Z}"
    echo "    collector                                       ${D}~/.local/bin/collector → repo${Z}"
    echo
    echo "  ${D}code — ~/Code/chat-collector/${Z}"
    echo "    collector                                       ${D}on/off/status/doctor/where${Z}"
    echo "    chat_collector.py                               ${D}addon: what to catch, where to write${Z}"
    echo "    com.chat-collector.plist                        ${D}the always-on service definition${Z}"
    echo "    sudoers.snippet                                 ${D}the passwordless on/off rule${Z}"
    echo
    echo "  ${D}installed into the system${Z}"
    echo "    ~/Library/LaunchAgents/com.chat-collector.plist ${D}makes it always-on${Z}"
    echo "    /etc/sudoers.d/chat-collector                   ${D}silent on/off${Z}"
    echo "    ~/.mitmproxy/mitmproxy-ca-cert.pem              ${D}the HTTPS key${Z}"
    echo
    echo "  ${D}what it produces${Z}"
    echo "    ~/chat-dumps/<service>/<id>.json                ${D}the captured conversations${Z}"
    echo "    /tmp/chat-collector.log                         ${D}what the recorder is doing${Z}"
    echo
    ;;
  *) echo "usage: collector on|off|status [-v]|doctor|where"; exit 1;;
esac
